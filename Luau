-- Save spawn/base position
local baseCFrame = nil
local function saveBase()
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart", 3)
    if hrp then
        baseCFrame = hrp.CFrame
    end
end
saveBase()

-- Teleport
local function tpToBase()
    if not baseCFrame then return end
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = baseCFrame
    end
end

-- Draggable (only from title bar)
local dragging = false
local dragInput, dragStart, startPos

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

titleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and dragInput == input then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Button actions
closeButton.MouseButton1Click:Connect(function()
    mainFrame.Visible = false
end)

tpButton.MouseButton1Click:Connect(tpToBase)

discordButton.MouseButton1Click:Connect(function()
    local link = "https://discord.gg/Zw6Vyv6BZ"
    pcall(function() setclipboard(link) end)
    StarterGui:SetCore("SendNotification", {
        Title = "Discord",
        Text = "Invite copied! → " .. link,
        Duration = 8
    })
end)

-- Reopen with INSERT key
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.Insert then
        mainFrame.Visible = not mainFrame.Visible
    end
end)

StarterGui:SetCore("SendNotification", {
    Title = "🧠 Small Brainrot GUI",
    Text = "Drag title • INSERT to toggle",
    Duration = 6
})
