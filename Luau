-- Toggle function
local function createToggle(name, yPos, default)
    local toggleFrame = Instance.new("Frame")
    toggleFrame.Size = UDim2.new(0.9, 0, 0, 38)
    toggleFrame.Position = UDim2.new(0.05, 0, yPos, 0)
    toggleFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)  -- Dark Gray
    toggleFrame.Parent = frame
    
    local tCorner = Instance.new("UICorner")
    tCorner.CornerRadius = UDim.new(0, 10)
    tCorner.Parent = toggleFrame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.65, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.GothamSemibold
    label.TextScaled = true
    label.Parent = toggleFrame
    
    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(0.3, 0, 1, 0)
    status.Position = UDim2.new(0.67, 0, 0, 0)
    status.BackgroundTransparency = 1
    status.Text = default and "ON" or "OFF"
    status.TextColor3 = default and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(180, 0, 0)
    status.TextScaled = true
    status.Font = Enum.Font.GothamBold
    status.Parent = toggleFrame
    
    toggleFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if name == "Anti-Kick" then
                antiKickEnabled = not antiKickEnabled
                status.Text = antiKickEnabled and "ON" or "OFF"
                status.TextColor3 = antiKickEnabled and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(180, 0, 0)
            elseif name == "Anti-Ban" then
                antiBanEnabled = not antiBanEnabled
                status.Text = antiBanEnabled and "ON" or "OFF"
                status.TextColor3 = antiBanEnabled and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(180, 0, 0)
            elseif name == "Anti-Detective" then
                antiDetectiveEnabled = not antiDetectiveEnabled
                status.Text = antiDetectiveEnabled and "ON" or "OFF"
                status.TextColor3 = antiDetectiveEnabled and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(180, 0, 0)
            end
        end
    end)
end

createToggle("Anti-Kick", 0.55, true)
createToggle("Anti-Ban", 0.72, true)
createToggle("Anti-Detective", 0.89, true)

-- Make GUI draggable (drag from title)
local dragging = false
local dragStart, startPos

title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

