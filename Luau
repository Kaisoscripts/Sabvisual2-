local player = game.Players.LocalPlayer
local baseCFrame = nil
local antiKickEnabled = true
local antiBanEnabled = true
local antiDetectiveEnabled = true

-- Save spawn position as base
local function saveBasePosition(char)
    if baseCFrame then return end
    local root = char:WaitForChild("HumanoidRootPart", 5)
    if root then
        baseCFrame = root.CFrame
        print("✅ Base position saved (your spawn)")
    end
end

player.CharacterAdded:Connect(saveBasePosition)
if player.Character then saveBasePosition(player.Character) end

-- === Basic Anti-Kick ===
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if antiKickEnabled then
        if method == "Kick" or (method == "FireServer" and (self.Name:lower():find("kick") or self.Name:lower():find("ban"))) then
            print("🛡️ Anti-Kick blocked a kick attempt!")
            return
        end
    end
    
    return oldNamecall(self, ...)
end)

setreadonly(mt, true)

-- Anti-Ban hook
game.Players.PlayerRemoving:Connect(function(plr)
    if plr == player and antiBanEnabled then
        print("🛡️ Anti-Ban: Prevented sudden removal detection")
    end
end)

-- Anti-Detective
local function applyAntiDetective(char)
    if not antiDetectiveEnabled then return end
    local humanoid = char:WaitForChild("Humanoid", 3)
    local head = char:FindFirstChild("Head")
    
    if humanoid then
        humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
    end
    
    if head and head:FindFirstChild("Nametag") then
        head.Nametag:Destroy()
    end
end

player.CharacterAdded:Connect(applyAntiDetective)
if player.Character then applyAntiDetective(player.Character) end

